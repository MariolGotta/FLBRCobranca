# Token do bot (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=seu_token_aqui

# ID do servidor Discord (clique com botão direito no servidor → Copiar ID)
DISCORD_GUILD_ID=123456789012345678

# ID do canal onde o bot vai postar notificações de novos membros
DISCORD_ADMIN_CHANNEL_ID=987654321098765432

# Token secreto compartilhado com o Flask (gere um aleatório: python -c "import secrets; print(secrets.token_hex(32))")
BOT_API_SECRET=troque_por_um_token_aleatorio

# URL base do site Flask (sem barra no final)
FLASK_API_URL=http://localhost:5000

# URL pública do site (exibida no DM para o jogador)
SITE_URL=https://seusite.com
